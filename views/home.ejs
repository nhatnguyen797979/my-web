<%- include('partials/header', { title: 'Trang chủ' }) %>
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="pill">Starter full web</span>
      <h1><%= site.hero_title %></h1>
      <p><%= site.hero_subtitle %></p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="<%= site.banner_cta_primary %>">Vào store</a>
        <a class="btn btn-secondary" href="<%= site.banner_cta_secondary %>">Dùng tool free</a>
      </div>
    </div>
    <div class="hero-card">
      <div class="stat"><strong><%= products.length %>+</strong><span>Sản phẩm</span></div>
      <div class="stat"><strong><%= tools.length %>+</strong><span>Tool free</span></div>
      <div class="stat"><strong><%= resources.length %>+</strong><span>Tài nguyên số</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head"><h2>Sản phẩm nổi bật</h2><a href="/store">Xem tất cả</a></div>
    <div class="grid cards-3">
      <% products.forEach(item => { %>
        <article class="card">
          <img src="<%= item.image_url %>" alt="<%= item.name %>" class="card-image" />
          <div class="card-body">
            <span class="badge"><%= item.badge %></span>
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
            <div class="card-row"><strong><%= item.price %></strong><a href="/store/product/<%= item.slug %>">Chi tiết</a></div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-head"><h2>Tool miễn phí</h2><a href="/tools">Xem tất cả</a></div>
    <div class="grid cards-3">
      <% tools.forEach(item => { %>
        <article class="card slim">
          <div class="card-body">
            <span class="badge"><%= item.badge %></span>
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
            <a href="/tools/<%= item.slug %>">Mở tool</a>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head"><h2>Tài nguyên số</h2><a href="/resources">Xem tất cả</a></div>
    <div class="grid cards-3">
      <% resources.forEach(item => { %>
        <article class="card slim">
          <div class="card-body">
            <span class="badge"><%= item.badge %></span>
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
            <div class="card-row"><strong><%= item.price %></strong><a href="/resources/<%= item.slug %>">Chi tiết</a></div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-head"><h2>Bài viết mới</h2><a href="/blog">Xem blog</a></div>
    <div class="grid cards-3">
      <% posts.forEach(item => { %>
        <article class="card slim">
          <div class="card-body">
            <h3><%= item.title %></h3>
            <p><%= item.excerpt %></p>
            <a href="/blog/<%= item.slug %>">Đọc tiếp</a>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
