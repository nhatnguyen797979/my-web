<%- include('partials/header', { title: product.name }) %>
<section class="section"><div class="container two-col"><div><img src="<%= product.image_url %>" alt="<%= product.name %>" class="hero-image" /><h1><%= product.name %></h1><p><%= product.description %></p><div class="price"><%= product.price %></div></div><aside class="sidebar-card"><h3>Mua nhanh</h3><form method="post" action="/buy" class="stack-form"><input type="hidden" name="item_type" value="product" /><input type="hidden" name="item_name" value="<%= product.name %>" /><input type="hidden" name="amount" value="<%= product.price %>" /><label>Tên khách<input type="text" name="customer_name" required /></label><label>Email<input type="email" name="customer_email" required /></label><button class="btn btn-primary" type="submit">Tạo đơn mẫu</button></form></aside></div></section>
<%- include('partials/footer') %>
