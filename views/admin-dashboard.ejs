<%- include('partials/header', { title: 'Admin' }) %>
<section class="section"><div class="container"><div class="section-head"><h1>Admin dashboard</h1><form method="post" action="/admin/logout"><button class="btn btn-secondary" type="submit">Đăng xuất</button></form></div><div class="grid cards-5"><div class="mini-card"><strong><%= stats.tools %></strong><span>Tools</span></div><div class="mini-card"><strong><%= stats.products %></strong><span>Products</span></div><div class="mini-card"><strong><%= stats.resources %></strong><span>Resources</span></div><div class="mini-card"><strong><%= stats.posts %></strong><span>Posts</span></div><div class="mini-card"><strong><%= stats.orders %></strong><span>Orders</span></div></div><div class="callout">Vào <a href="/admin/content">trang quản trị nội dung</a> để thêm, sửa, xóa giao diện và nội dung.</div><div class="card"><div class="card-body"><h3>Đơn gần đây</h3><table class="table"><thead><tr><th>ID</th><th>Khách</th><th>Mặt hàng</th><th>Số tiền</th><th>Trạng thái</th></tr></thead><tbody><% latestOrders.forEach(order => { %><tr><td>#<%= order.id %></td><td><%= order.customer_name %></td><td><%= order.item_name %></td><td><%= order.amount %></td><td><%= order.status %></td></tr><% }) %></tbody></table></div></div></div></section>
<%- include('partials/footer') %>
