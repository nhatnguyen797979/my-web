<%- include('partials/header', { title: resource.name }) %>
<section class="section"><div class="container two-col"><div><span class="pill"><%= resource.file_type %></span><h1><%= resource.name %></h1><p><%= resource.description %></p><div class="price"><%= resource.price %></div></div><aside class="sidebar-card"><h3>Lấy tài nguyên</h3><form method="post" action="/buy" class="stack-form"><input type="hidden" name="item_type" value="resource" /><input type="hidden" name="item_name" value="<%= resource.name %>" /><input type="hidden" name="amount" value="<%= resource.price %>" /><label>Tên khách<input type="text" name="customer_name" required /></label><label>Email<input type="email" name="customer_email" required /></label><button class="btn btn-primary" type="submit">Tạo đơn mẫu</button></form></aside></div></section>
<%- include('partials/footer') %>
