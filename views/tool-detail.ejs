<%- include('partials/header', { title: tool.name }) %>
<section class="section">
  <div class="container two-col">
    <div>
      <span class="pill"><%= tool.badge %></span>
      <h1><%= tool.name %></h1>
      <p><%= tool.description %></p>
      <% if (tool.slug === 'download-image') { %>
      <form class="tool-form">
        <label>Link URL<input type="text" placeholder="Dán link web hoặc social công khai" /></label>
        <div class="grid cards-2">
          <label>Min width<input type="number" value="1000" /></label>
          <label>Min height<input type="number" value="1000" /></label>
          <label>Kiểu ảnh<select><option>Tất cả</option><option>Ngang</option><option>Dọc</option><option>Vuông</option></select></label>
          <label>Số lượng tối đa<input type="number" value="50" /></label>
        </div>
        <div class="inline-checks">
          <label><input type="checkbox" checked /> Auto scroll</label>
          <label><input type="checkbox" checked /> Crawl cùng domain</label>
          <label><input type="checkbox" checked /> Ưu tiên ảnh gốc</label>
        </div>
        <button type="button" class="btn btn-primary">Nút demo giao diện</button>
      </form>
      <% } else { %>
      <div class="callout">Trang giữ chỗ để bạn thêm logic thật cho tool này sau.</div>
      <% } %>
    </div>
    <aside class="sidebar-card">
      <h3>Gợi ý đặt tool</h3>
      <ul>
        <li>Cho khách dùng miễn phí để tăng tương tác.</li>
        <li>Đặt CTA sang store ở cạnh tool.</li>
        <li>Thêm tracking để biết tool nào kéo chuyển đổi tốt.</li>
      </ul>
      <a class="btn btn-secondary" href="/store">Xem sản phẩm chính</a>
    </aside>
  </div>
</section>
<%- include('partials/footer') %>
