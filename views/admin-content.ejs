<%- include('partials/header', { title: 'Admin Content' }) %>
<section class="section"><div class="container"><div class="section-head"><h1>Quản trị nội dung</h1><a class="btn btn-secondary" href="/admin">Về dashboard</a></div>

<div class="admin-grid">
  <section class="card"><div class="card-body"><h2>Thiết lập website</h2><form class="stack-form" method="post" action="/admin/settings">
    <% ['site_name','site_tagline','hero_title','hero_subtitle','contact_email','telegram','zalo','banner_cta_primary','banner_cta_secondary'].forEach(key => { %>
      <label><%= key %><input type="text" name="<%= key %>" value="<%= settings[key] || '' %>" /></label>
    <% }) %>
    <button class="btn btn-primary" type="submit">Lưu thiết lập</button>
  </form></div></section>

  <section class="card"><div class="card-body"><h2>Thêm section homepage</h2><form class="stack-form" method="post" action="/admin/item/homepage_sections/create"><label>Tên nội bộ<input name="name" /></label><label>Tiêu đề<input name="title" /></label><label>Phụ đề<textarea name="subtitle"></textarea></label><label>Thứ tự<input name="sort_order" type="number" value="0" /></label><label><input type="checkbox" name="is_visible" checked /> Hiển thị</label><button class="btn btn-primary">Thêm section</button></form></div></section>

  <section class="card"><div class="card-body"><h2>Sections hiện có</h2><% sections.forEach(item => { %><form class="stack-form item-form" method="post" action="/admin/item/homepage_sections/<%= item.id %>/update"><label>Tên<input name="name" value="<%= item.name %>" /></label><label>Tiêu đề<input name="title" value="<%= item.title %>" /></label><label>Phụ đề<textarea name="subtitle"><%= item.subtitle %></textarea></label><label>Thứ tự<input type="number" name="sort_order" value="<%= item.sort_order %>" /></label><label><input type="checkbox" name="is_visible" <%= item.is_visible ? 'checked' : '' %> /> Hiển thị</label><div class="row-actions"><button class="btn btn-primary">Lưu</button></form><form method="post" action="/admin/item/homepage_sections/<%= item.id %>/delete"><button class="btn btn-danger">Xóa</button></form></div><hr><% }) %></div></section>

  <section class="card"><div class="card-body"><h2>Thêm tool</h2><form class="stack-form" method="post" action="/admin/item/tools/create"><label>Tên<input name="name" /></label><label>Slug<input name="slug" /></label><label>Mô tả<textarea name="description"></textarea></label><label>Badge<input name="badge" value="Free" /></label><label>Category<input name="category" value="Utility" /></label><label>Thứ tự<input type="number" name="sort_order" value="0" /></label><label><input type="checkbox" name="is_visible" checked /> Hiển thị</label><button class="btn btn-primary">Thêm tool</button></form></div></section>

  <section class="card"><div class="card-body"><h2>Tools hiện có</h2><% tools.forEach(item => { %><form class="stack-form item-form" method="post" action="/admin/item/tools/<%= item.id %>/update"><label>Tên<input name="name" value="<%= item.name %>" /></label><label>Slug<input name="slug" value="<%= item.slug %>" /></label><label>Mô tả<textarea name="description"><%= item.description %></textarea></label><label>Badge<input name="badge" value="<%= item.badge %>" /></label><label>Category<input name="category" value="<%= item.category %>" /></label><label>Thứ tự<input type="number" name="sort_order" value="<%= item.sort_order %>" /></label><label><input type="checkbox" name="is_visible" <%= item.is_visible ? 'checked' : '' %> /> Hiển thị</label><div class="row-actions"><button class="btn btn-primary">Lưu</button></form><form method="post" action="/admin/item/tools/<%= item.id %>/delete"><button class="btn btn-danger">Xóa</button></form></div><hr><% }) %></div></section>

  <section class="card"><div class="card-body"><h2>Thêm sản phẩm</h2><form class="stack-form" method="post" action="/admin/item/products/create"><label>Tên<input name="name" /></label><label>Slug<input name="slug" /></label><label>Mô tả<textarea name="description"></textarea></label><label>Giá<input name="price" /></label><label>Category<input name="category" value="Service" /></label><label>Badge<input name="badge" value="Hot" /></label><label>Ảnh URL<input name="image_url" value="https://placehold.co/800x500?text=Product" /></label><label>Thứ tự<input type="number" name="sort_order" value="0" /></label><label><input type="checkbox" name="is_visible" checked /> Hiển thị</label><button class="btn btn-primary">Thêm sản phẩm</button></form></div></section>

  <section class="card"><div class="card-body"><h2>Sản phẩm hiện có</h2><% products.forEach(item => { %><form class="stack-form item-form" method="post" action="/admin/item/products/<%= item.id %>/update"><label>Tên<input name="name" value="<%= item.name %>" /></label><label>Slug<input name="slug" value="<%= item.slug %>" /></label><label>Mô tả<textarea name="description"><%= item.description %></textarea></label><label>Giá<input name="price" value="<%= item.price %>" /></label><label>Category<input name="category" value="<%= item.category %>" /></label><label>Badge<input name="badge" value="<%= item.badge %>" /></label><label>Ảnh URL<input name="image_url" value="<%= item.image_url %>" /></label><label>Thứ tự<input type="number" name="sort_order" value="<%= item.sort_order %>" /></label><label><input type="checkbox" name="is_visible" <%= item.is_visible ? 'checked' : '' %> /> Hiển thị</label><div class="row-actions"><button class="btn btn-primary">Lưu</button></form><form method="post" action="/admin/item/products/<%= item.id %>/delete"><button class="btn btn-danger">Xóa</button></form></div><hr><% }) %></div></section>

  <section class="card"><div class="card-body"><h2>Thêm tài nguyên</h2><form class="stack-form" method="post" action="/admin/item/resources/create"><label>Tên<input name="name" /></label><label>Slug<input name="slug" /></label><label>Mô tả<textarea name="description"></textarea></label><label>Giá<input name="price" /></label><label>Loại file<input name="file_type" value="ZIP" /></label><label>Badge<input name="badge" value="New" /></label><label>Thứ tự<input type="number" name="sort_order" value="0" /></label><label><input type="checkbox" name="is_visible" checked /> Hiển thị</label><button class="btn btn-primary">Thêm tài nguyên</button></form></div></section>

  <section class="card"><div class="card-body"><h2>Tài nguyên hiện có</h2><% resources.forEach(item => { %><form class="stack-form item-form" method="post" action="/admin/item/resources/<%= item.id %>/update"><label>Tên<input name="name" value="<%= item.name %>" /></label><label>Slug<input name="slug" value="<%= item.slug %>" /></label><label>Mô tả<textarea name="description"><%= item.description %></textarea></label><label>Giá<input name="price" value="<%= item.price %>" /></label><label>Loại file<input name="file_type" value="<%= item.file_type %>" /></label><label>Badge<input name="badge" value="<%= item.badge %>" /></label><label>Thứ tự<input type="number" name="sort_order" value="<%= item.sort_order %>" /></label><label><input type="checkbox" name="is_visible" <%= item.is_visible ? 'checked' : '' %> /> Hiển thị</label><div class="row-actions"><button class="btn btn-primary">Lưu</button></form><form method="post" action="/admin/item/resources/<%= item.id %>/delete"><button class="btn btn-danger">Xóa</button></form></div><hr><% }) %></div></section>

  <section class="card"><div class="card-body"><h2>Thêm bài viết</h2><form class="stack-form" method="post" action="/admin/item/posts/create"><label>Tiêu đề<input name="title" /></label><label>Slug<input name="slug" /></label><label>Tóm tắt<textarea name="excerpt"></textarea></label><label>Nội dung<textarea name="content"></textarea></label><label>Thứ tự<input type="number" name="sort_order" value="0" /></label><label><input type="checkbox" name="is_visible" checked /> Hiển thị</label><button class="btn btn-primary">Thêm bài</button></form></div></section>

  <section class="card"><div class="card-body"><h2>Bài viết hiện có</h2><% posts.forEach(item => { %><form class="stack-form item-form" method="post" action="/admin/item/posts/<%= item.id %>/update"><label>Tiêu đề<input name="title" value="<%= item.title %>" /></label><label>Slug<input name="slug" value="<%= item.slug %>" /></label><label>Tóm tắt<textarea name="excerpt"><%= item.excerpt %></textarea></label><label>Nội dung<textarea name="content"><%= item.content %></textarea></label><label>Thứ tự<input type="number" name="sort_order" value="<%= item.sort_order %>" /></label><label><input type="checkbox" name="is_visible" <%= item.is_visible ? 'checked' : '' %> /> Hiển thị</label><div class="row-actions"><button class="btn btn-primary">Lưu</button></form><form method="post" action="/admin/item/posts/<%= item.id %>/delete"><button class="btn btn-danger">Xóa</button></form></div><hr><% }) %></div></section>

  <section class="card full-span"><div class="card-body"><h2>Đơn hàng</h2><table class="table"><thead><tr><th>ID</th><th>Khách</th><th>Email</th><th>Loại</th><th>Tên</th><th>Giá</th><th>Trạng thái</th><th></th></tr></thead><tbody><% orders.forEach(item => { %><tr><td>#<%= item.id %></td><td><%= item.customer_name %></td><td><%= item.customer_email %></td><td><%= item.item_type %></td><td><%= item.item_name %></td><td><%= item.amount %></td><td><%= item.status %></td><td><form method="post" action="/admin/item/orders/<%= item.id %>/delete"><button class="btn btn-danger small">Xóa</button></form></td></tr><% }) %></tbody></table></div></section>
</div>
</div></section>
<%- include('partials/footer') %>
